{
    "name": "wal3fo/laravel-sentinel",
    "description": "Production-ready circuit breaker package for Laravel queue jobs and service calls.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "circuit-breaker",
        "queue",
        "resilience",
        "sentinel"
    ],
    "require": {
        "php": "^8.1",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/config": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/events": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Wal3fo\\LaravelSentinel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wal3fo\\LaravelSentinel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wal3fo\\LaravelSentinel\\SentinelServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
